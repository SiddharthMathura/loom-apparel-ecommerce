<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/shop.css">
    <title>navbar</title>
</head>
<body>
    <nav class="navbar">
        <% if(adminData && adminData.products) { %>
            <div class="nav-left">
                <button class="sidebar-toggle">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <span class="nav-title">Admin</span>
            </div>
        <% } %> 
        <% if (userData || guestData ) { %>
            <div class="nav-left">
                <button class="sidebar-toggle">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <span class="nav-title">SHOP</span>
            </div>
        <% } %>
        <div class="nav-right">
            <% if (userData) { %>
                <a href="/users/cart" class="nav-link"> Cart </a>
                <a href="/users/account" class="nav-link"><img class="account-image" src="/images/<%= userData.profilePicture %>"> <%= userData.fullname %> </a>
            <% } %> 
            <% if (guestData) { %>
                <a href="/guest/cart" class="nav-link"> Cart</a>
                <a href="/" class="nav-link"> <img class="account-image" src="/images/defaultProfilePicture.jpg"> <%= guestData.fullname %> </a>
            <% } %>
            <% if (adminData && adminData.products) { %>
                <!-- <a href="/admins/cart" class="nav-link"> Cart </a> -->
                <a href="/admins/account" class="nav-link"><img class="account-image" src="/images/<%= adminData.profilePicture %>"> <%= adminData.fullname %> </a>
            <% } %>
        </div>
    </nav>
</body>
</html>